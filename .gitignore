# Git ignore file
# Exclude sensitive files from version control

# Note: firebase-config.js and admin.js are now committed to GitHub
# (They contain the production Firebase config needed for GitHub Pages)

# Node modules (if using npm)
node_modules/
npm-debug.log

# IDE specific files
.vscode/
.idea/
*.swp
*.swo
*~

# OS specific
.DS_Store
Thumbs.db

# Environment files
.env
.env.local
.env.*.local

# Build artifacts
dist/
build/

# Temporary files
*.tmp
*.bak
*.log
